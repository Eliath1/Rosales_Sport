# Database (Neon PostgreSQL) - same value as apps/web's .env (ADR-014: one
# shared Neon project, two apps).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js (staff login)
# Generate: openssl rand -base64 32 - use a DIFFERENT secret than apps/web,
# they are separate NextAuth instances with separate session cookies.
AUTH_SECRET=""
AUTH_URL="http://localhost:3001"

# Email (Resend) - quote PDFs / staff-triggered notifications
RESEND_API_KEY=""
EMAIL_FROM="cotizaciones@rosalessport.com"

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3001"
