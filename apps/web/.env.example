# Database (Neon PostgreSQL) - same value as apps/admin's .env (ADR-014:
# one shared Neon project, two apps).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js (customer login, /mi-cuenta/*)
# Generate: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Email (Resend) - order confirmations sent from checkout
RESEND_API_KEY=""
EMAIL_FROM="cotizaciones@rosalessport.com"

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Cross-domain link to the staff CRM (see components/site-header.tsx) - the
# two apps never call each other over HTTP, this is just a login link.
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"

# Cloudflare R2 (product images, optional for Wave 0)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Cloudflare Turnstile (public forms: quote/leads, production)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Payments (ADR-006, ADR-013)
# "mock" (default, no credentials needed) or "mercadopago". Do not set to
# "mercadopago" until MERCADOPAGO_ACCESS_TOKEN below is a real sandbox/live
# token and a security-reviewer sign-off has happened (see AGENTS.md).
PAYMENT_PROVIDER="mock"
# Sandbox tokens start with "TEST-"; live tokens do not.
MERCADOPAGO_ACCESS_TOKEN=""
# Used to verify the x-signature header on incoming webhooks - get this from
# the Mercado Pago dashboard webhook configuration, not the access token.
MERCADOPAGO_WEBHOOK_SECRET=""
