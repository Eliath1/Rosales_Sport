# Neon PostgreSQL - shared by apps/web and apps/admin (see ADR-014).
# Used when running Prisma commands (generate/migrate/seed) directly from
# packages/db. Each app also needs its own copy of this same value in its
# own .env for `next dev`/`next build` (Next.js does not read parent or
# sibling .env files).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
